# ═══════════════════════════════════════════════════════════════
# ORVIKA AI — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────
dist/
dist-ssr/
*.tgz

# ── Rust / Tauri ──────────────────────────────────────────────
src-tauri/target/
src-tauri/WixTools/
src-tauri/gen/schemas/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# ── App data (local dev databases) ───────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Binaries & native modules ────────────────────────────────
bin/
*.dll
*.so
*.dylib
*.exe
*.out

# ── Python cache & virtual environments ──────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
ENV/
env/
*.egg-info/
.eggs/

# ── Graphify (AST code graph tool) ───────────────────────────
graphify-out/
.graphify/

# ── Local agent/tool rules ───────────────────────────────────
.agents/

# ── Temporary context & sprint extraction files ──────────────
CONTEXT/

# ── Vitest & test coverage ───────────────────────────────────
coverage/
.vitest/

# ── Playwright E2E test artifacts ────────────────────────────
test-results/
playwright-report/
blob-report/

# ── Local history / backups ──────────────────────────────────
.history/
*.local
*.bak
*.tmp
*.temp

# ── GGUF model files (very large, never commit) ─────────────
models/downloads/
*.gguf

# ── llama.cpp binaries (downloaded at runtime) ───────────────
llama-server*
llama-cli*

# ── Embedding model files ────────────────────────────────────
*.onnx
*.safetensors

# ── Misc ─────────────────────────────────────────────────────
.turbo/
.next/
.nuxt/
.cache/
